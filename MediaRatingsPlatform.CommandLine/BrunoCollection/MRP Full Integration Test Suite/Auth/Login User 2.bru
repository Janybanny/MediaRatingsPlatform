meta {
  name: Login User 2
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/users/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "user2",
    "password": "pass123"
  }
}

assert {
  res.status: eq 200
  res.body: length 36
}

script:post-response {
  bru.setVar("token2", res.body);
}

settings {
  encodeUrl: true
  timeout: 0
}
