meta {
  name: Register User 1
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/users/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "user1",
    "password": "pass123"
  }
}

assert {
  res.status: eq 201
}

settings {
  encodeUrl: true
  timeout: 0
}
