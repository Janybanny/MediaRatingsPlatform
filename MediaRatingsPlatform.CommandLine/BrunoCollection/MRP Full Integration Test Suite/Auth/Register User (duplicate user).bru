meta {
  name: Register User (duplicate user)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/users/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "user2",
    "password": "pass123"
  }
}

assert {
  res.status: eq 409
}

settings {
  encodeUrl: true
  timeout: 0
}
