meta {
  name: Login User Bad Password
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/users/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "user1",
    "password": "pass123bad"
  }
}

assert {
  res.status: eq 401
}

settings {
  encodeUrl: true
  timeout: 0
}
