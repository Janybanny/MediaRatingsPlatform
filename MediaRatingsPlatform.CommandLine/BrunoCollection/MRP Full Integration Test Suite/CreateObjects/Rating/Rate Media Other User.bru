meta {
  name: Rate Media Other User
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/media/1/rate
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{token2}}
}

body:json {
  {
    "stars": 4,
    "comment": "Amazing movie!"
  }
}

assert {
  res.status: eq 201
}

settings {
  encodeUrl: true
  timeout: 0
}
