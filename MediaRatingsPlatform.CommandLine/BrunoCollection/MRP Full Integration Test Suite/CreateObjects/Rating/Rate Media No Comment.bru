meta {
  name: Rate Media No Comment
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/media/2/rate
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "stars": 1,
    "comment": ""
  }
}

assert {
  res.status: eq 201
}

settings {
  encodeUrl: true
  timeout: 0
}
