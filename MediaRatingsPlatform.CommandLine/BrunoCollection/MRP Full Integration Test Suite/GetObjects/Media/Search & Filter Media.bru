meta {
  name: Search & Filter Media
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/media?title=tit&sortBy=score&genre=genre3
  body: none
  auth: inherit
}

params:query {
  title: tit
  sortBy: score
  genre: genre3
}

assert {
  res.status: eq 200
  res.body[0].Id: eq 2
  res.body[1].Id: eq 3
  res.body[0].Ratings[0].Stars: eq 2
}

settings {
  encodeUrl: true
  timeout: 0
}
