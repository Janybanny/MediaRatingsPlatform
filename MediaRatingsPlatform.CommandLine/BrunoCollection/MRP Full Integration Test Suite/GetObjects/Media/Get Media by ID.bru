meta {
  name: Get Media by ID
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/media/1
  body: none
  auth: inherit
}

params:query {
  : 
}

assert {
  res.status: eq 200
  res.body.Id: eq 1
  res.body.Genres[0]: eq genre1
  res.body.Ratings[0].Id: eq 3
  res.body.Ratings[0].Comment: isNull
}

settings {
  encodeUrl: true
  timeout: 0
}
