meta {
  name: Get Profile
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/users/1/profile
  body: none
  auth: inherit
}

assert {
  res.status: eq 200
  res.body: isJson
  res.body.Id: eq 1
  res.body.Username: eq user1
  res.body.EMail: eq user1@example.com
  res.body.FavoriteGenre: eq genre1
  res.body.TotalMediaStatistic: eq 3
  res.body.TotalRatingsStatistic: eq 2
  res.body.AverageRatingStatistic: eq 3
  res.body.Password: isNull
}

script:post-response {
  bru.setVar("body", res.body);
}

settings {
  encodeUrl: true
  timeout: 0
}
